<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <PublishAot>true</PublishAot>
        <InvariantGlobalization>true</InvariantGlobalization>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    </PropertyGroup>

    <ItemGroup>
      <ProjectReference Include="..\AqueousBindings\AstalGTK4\AstalGTK4.csproj" />
      <ProjectReference Include="..\AqueousBindings\AstalApp\AstalApp.csproj" />
    </ItemGroup>

    <ItemGroup>
      <Reference Include="AstalBindings">
        <HintPath>bin\Debug\net10.0\AstalBindings.dll</HintPath>
      </Reference>
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="GirCore.Gtk-4.0" Version="0.7.0" />
    </ItemGroup>

</Project>
