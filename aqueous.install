post_install() {
    echo "==> Running Aqueous Wayfire keybinding setup..."
    # Run as each logged-in user who has a wayfire.ini
    for user_home in /home/*; do
        user=$(basename "$user_home")
        if [ -f "$user_home/.config/wayfire.ini" ]; then
            su -c "/usr/lib/aqueous/aqueous-wayfire-setup.sh" "$user" 2>/dev/null || true
        fi
    done
}

post_upgrade() {
    post_install
}
