<?xml version="1.0"?>
<wayfire>
    <plugin name="aqueous-corners">
        <_short>Aqueous Corners</_short>
        <_long>Rounded corners for all windows (Vulkan compatible)</_long>
        <category>Effects</category>
        <option name="corner_radius" type="int">
            <_short>Corner radius</_short>
            <default>12</default>
            <min>0</min>
            <max>30</max>
        </option>
        <option name="corner_color" type="color">
            <_short>Corner fill color</_short>
            <default>0.1 0.1 0.1 1.0</default>
        </option>
        <option name="enabled" type="bool">
            <_short>Enable corner rounding</_short>
            <default>true</default>
        </option>
        <option name="exclude_maximized" type="bool">
            <_short>Skip maximized and fullscreen windows</_short>
            <default>true</default>
        </option>
    </plugin>
</wayfire>
